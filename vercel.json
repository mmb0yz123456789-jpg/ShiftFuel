{
  "crons": [
    {
      "path": "/api/auto-reverse-payments",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/staff/access", "destination": "/staff-access.html" },
    { "source": "/join-the-team", "destination": "/hiring.html" },
    { "source": "/apply", "destination": "/hiring.html" },
    { "source": "/worker/login", "destination": "/worker-login.html" },
    { "source": "/worker/dashboard", "destination": "/worker.html" },
    { "source": "/admin/login", "destination": "/admin-login.html" },
    { "source": "/admin/dashboard", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
